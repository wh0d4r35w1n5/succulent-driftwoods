{
  "version": "2.0.0",
  "inputs": [
    {
      "id": "psCommand",
      "type": "promptString",
      "description": "PowerShell command to run",
      "default": "Write-Host \"Hello from PowerShell\""
    },
    {
      "id": "cmdCommand",
      "type": "promptString",
      "description": "CMD command to run",
      "default": "echo Hello from CMD"
    }
  ],
  "tasks": [
    {
      "label": "Run PowerShell (prompt)",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-Command",
        "${input:psCommand}"
      ],
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      }
    },
    {
      "label": "Run CMD (prompt)",
      "type": "shell",
      "command": "cmd",
      "args": [
        "/d",
        "/c",
        "${input:cmdCommand}"
      ],
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      }
    },
    {
      "label": "Run scripts\\run.ps1",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}\\\\scripts\\\\run.ps1"
      ],
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      }
    },
    {
      "label": "Run scripts\\run.cmd",
      "type": "shell",
      "command": "cmd",
      "args": [
        "/d",
        "/c",
        "${workspaceFolder}\\\\scripts\\\\run.cmd"
      ],
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      }
    },
    {
      "label": "Deploy to Netlify (prod)",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}\\\\scripts\\\\deploy-netlify.ps1"
      ],
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      }
    }
  ]
}

